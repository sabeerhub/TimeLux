# ─── SERVER ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/time_ng

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=4h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# ─── KORAPAY ───────────────────────────────────────────────
KORAPAY_PUBLIC_KEY=your_korapay_public_key
KORAPAY_SECRET_KEY=your_korapay_secret_key
KORAPAY_WEBHOOK_SECRET=your_korapay_webhook_secret
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1

# ─── CLOUDINARY ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APPLE_CLIENT_ID=com.yourapp.identifier
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── BACKEND URL (for OAuth callbacks) ─────────────────────
BACKEND_URL=https://your-backend.railway.app
